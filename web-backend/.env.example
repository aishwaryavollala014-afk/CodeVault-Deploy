# CodeVault web-backend — environment template.
# Copy to `.env` (gitignored) for local dev: `cp .env.example .env`
# Every variable here is validated at boot by src/config/env.ts (fail-fast).

# --- runtime ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# --- database (PostgreSQL) ---
# Host tooling (prisma migrate run from your machine) uses localhost.
# Inside Docker the compose file overrides host -> "postgres".
DATABASE_URL=postgresql://codevault:codevault@localhost:5432/codevault

# --- redis (cache + rate-limit) ---
REDIS_URL=redis://localhost:6379

# --- auth / crypto (CROWN JEWELS — never commit real values) ---
# JWT signing secret, shared with git-service so it can verify the same token.
JWT_SECRET=change-me-in-dev-use-a-long-random-string
JWT_ACCESS_TTL=1800            # access token lifetime, seconds (30 min)
JWT_REFRESH_TTL=1209600        # refresh token lifetime, seconds (14 days)
# 32-byte key (base64) for envelope-encrypting platform/GitHub tokens (AES-256-GCM).
ENCRYPTION_KEY=base64:replace-with-32-byte-key

# --- GitHub OAuth (sign-in) ---
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# --- CORS / frontend origin ---
CORS_ORIGIN=http://localhost:3000
