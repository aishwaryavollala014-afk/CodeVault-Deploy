# ---- dependencies ----
**/node_modules/
.pnp
.pnp.js

# ---- builds / output ----
**/dist/
**/build/
**/.next/
**/out/

# ---- env & secrets (NEVER commit) ----
.env
.env.*
!.env.example
!.env.docker.example

# ---- logs ----
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- prisma local db (SQLite, if ever used) ----
**/*.sqlite
**/*.sqlite-journal

# ---- coverage / test ----
**/coverage/

# ---- OS / editor junk ----
.DS_Store
**/.DS_Store
Thumbs.db
.idea/
.vscode/

# ---- archives / misc ----
*.zip

# ---- codebase-memory MCP (index artifact is local; re-index is instant) ----
.codebase-memory/

# ---- codex CLI (local MCP config) ----
.codex/
