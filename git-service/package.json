{
  "name": "codevault-git-service",
  "version": "0.1.0",
  "private": true,
  "description": "CodeVault git-service — fetches accepted solutions and syncs them to GitHub (Path B).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "axios": "^1.7.2",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pino": "^9.3.1",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.4",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.18"
  }
}
