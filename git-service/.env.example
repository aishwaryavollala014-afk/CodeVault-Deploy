# CodeVault git-service — environment template.
# Copy to `.env` (gitignored) for local dev. Validated at boot by src/config/env.ts.

# --- runtime ---
NODE_ENV=development
# macOS AirPlay Receiver occupies port 5000 — use 5050 locally
# (in Docker the container still binds 5000 internally).
PORT=5050
LOG_LEVEL=debug

# --- database (SAME Postgres as web-backend; git-service writes only problems + sync_runs) ---
DATABASE_URL=postgresql://codevault:codevault@localhost:5433/codevault

# --- redis (cache + BullMQ queue + per-connection locks) ---
REDIS_URL=redis://localhost:6380

# --- shared crypto (MUST match web-backend) ---
# Same JWT_SECRET so this service can verify the user's access token.
JWT_SECRET=must-match-web-backend
# Same ENCRYPTION_KEY (64 hex chars = 32 bytes) so this service can DECRYPT platform/GitHub tokens.
# Must match web-backend exactly (it uses Buffer.from(ENCRYPTION_KEY, 'hex')).
ENCRYPTION_KEY=must-match-web-backend-64-hex-chars

# --- sync scheduler ---
SYNC_CRON=0 */6 * * *
SYNC_CONCURRENCY=3
SYNC_PLATFORM_CONCURRENCY=2
# Kill switch — set to false to pause ALL sync (scheduler + manual trigger).
SYNC_ENABLED=true

# --- CORS (frontend origin; the browser calls this service directly with the user JWT) ---
CORS_ORIGIN=http://localhost:3000
