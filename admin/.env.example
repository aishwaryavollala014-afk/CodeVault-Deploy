# CodeVault Admin — environment template. Copy to `.env` (gitignored).

# Owner Postgres connection (RLS-bypass) — same DB as the rest of CodeVault.
DATABASE_URL=postgresql://codevault:codevault@localhost:5433/codevault?schema=public

# MUST match web-backend's JWT_SECRET so admin can verify the shared cv_access session cookie.
JWT_SECRET=

# Comma-separated GitHub logins allowed into the admin console (case-insensitive).
ADMIN_GITHUB_LOGINS=Gaurav06120714,aishwaryaV007
